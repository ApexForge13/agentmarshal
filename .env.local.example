# Gemini Pro API key. Used by lib/gemini-client.ts when calling the
# OpenAI-compatible endpoint via the Lobster Trap proxy.
GEMINI_API_KEY=

# Lobster Trap sidecar URL. The Go binary in ../lobstertrap/ listens here
# and exposes /v1/inspect and /v1/proxy/*.
LT_PROXY_URL=http://localhost:8080

# Vapi (https://vapi.ai) — sandbox phone number webhook target.
# SAMPLE voice agent (lib/voice/); production agent lives in echo-os.
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# AgentMarshal — agent identity this voice agent reports as.
AGENTMARSHAL_AGENT_ID=voice-001
# Public URL Vapi calls back to (ngrok during dev, fly.io subdomain for staging).
VOICE_WEBHOOK_PUBLIC_URL=
