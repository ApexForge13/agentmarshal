# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
# Exception: golden test fixtures hold a public-key-only PEM derived from a
# published seed. Production private keys are also *.pem but live under
# data/keys/ (gitignored above).
!tests/vectors/keys/*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# local audit DB
data/*.db
data/*.db-shm
data/*.db-wal

# local key custody (FileKeyProvider — production uses KMS)
data/keys/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
data/authzen-audit.db
